<?xml version="1.0" encoding="UTF-8"?>
<config xmlns="urn:ietf:params:xml:ns:netconf:base:1.0">
  <native xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-native">

    <!-- HOSTNAME -->
    <hostname>LAB-RA07-C02-R01</hostname>

    <!-- SERVICE TIMESTAMPS -->
    <service>
      <timestamps>
        <debug>
          <datetime>
            <msec/>
          </datetime>
        </debug>
        <log>
          <datetime>
            <msec/>
          </datetime>
        </log>
      </timestamps>
    </service>

    <!-- BANNER MOTD -->
    <banner>
      <motd>
        <banner>*** WAARSCHING: Enkel geautoriseerde toegang. Activiteiten worden gelogd. LAB-RA07-C02-R01 ***</banner>
      </motd>
    </banner>


    <!-- IP SETTINGS -->
    <ip>
      <domain>
        <name>lab.local</name>
      </domain>

      <!-- DNS -->
      <name-server>
        <no-vrf>
          <address>8.8.8.8</address>
          <address>8.8.4.4</address>
        </no-vrf>
      </name-server>

      <!-- HTTP volledig verwijderd i.p.v. false -->
    </ip>

    <!-- INTERFACES (ENKEL DESCRIPTION) -->
    <interface>
      <GigabitEthernet>
        <name>0/0/0</name>
        <description>TRUNK - Naar distributieswitch (VLAN 75/76/77/78/99)</description>
      </GigabitEthernet>
    </interface>

    <interface>
      <GigabitEthernet>
        <name>0/0/0.75</name>
        <description>VLAN 75 - Management | 172.17.7.64/28</description>
      </GigabitEthernet>
    </interface>

    <interface>
      <GigabitEthernet>
        <name>0/0/0.76</name>
        <description>VLAN 76 - Data Users | 172.17.7.80/28</description>
      </GigabitEthernet>
    </interface>

    <interface>
      <GigabitEthernet>
        <name>0/0/0.77</name>
        <description>VLAN 77 - Voice | 172.17.7.96/28</description>
      </GigabitEthernet>
    </interface>

    <interface>
      <GigabitEthernet>
        <name>0/0/0.78</name>
        <description>VLAN 78 - Reserved | 172.17.7.112/28</description>
      </GigabitEthernet>
    </interface>

    <interface>
      <GigabitEthernet>
        <name>0/0/0.99</name>
        <description>VLAN 99 - Native VLAN</description>
      </GigabitEthernet>
    </interface>

    <interface>
      <GigabitEthernet>
        <name>0/0/1</name>
        <description>WAN Uplink | 10.199.65.96/27</description>
      </GigabitEthernet>
    </interface>

    <!-- NTP -->
    <ntp>
      <server>
        <server-list>
          <ip-address>10.199.65.100</ip-address>
        </server-list>
      </server>
    </ntp>

    <!-- LOGGING -->
    <logging>
      <host>
        <ipv4-host-list>
          <ipv4-host>10.199.64.66</ipv4-host>
        </ipv4-host-list>
      </host>
      <trap>informational</trap>
    </logging>

  </native>
</config>
