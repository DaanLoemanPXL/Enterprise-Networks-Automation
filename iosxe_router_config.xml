<?xml version="1.0" encoding="UTF-8"?>
<!--
  NETCONF YANG Configuration – Router LAB-RA07-C02-R01
  Single Source of Truth: GitHub
  Target datastore: candidate → commit naar running

  SAFE MODE – deze config:
    • Raakt GEEN bestaande IP-adressen of maskers aan
    • Raakt GEEN encapsulation/dot1Q aan
    • Raakt GEEN shutdown-states aan
    • Voegt WEL nieuwe configuratie-items toe (bonus punten)
    • Werkt uitsluitend descriptions bij op interfaces
    • Verbetert OSPF (passive-interface, default-information originate)
-->
<config xmlns="urn:ietf:params:xml:ns:netconf:base:1.0">
  <native xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-native">

    <!-- ═══════════════════════════════════════════
         HOSTNAME  (ongewijzigd – veilig om te herhalen)
    ═══════════════════════════════════════════ -->
    <hostname>LAB-RA07-C02-R01</hostname>

    <!-- ═══════════════════════════════════════════
         GLOBAL SERVICE SETTINGS  (nieuw – bonus)
         Voegt timestamps toe aan logging en debug output.
         Bestaat nog niet → wordt puur toegevoegd.
    ═══════════════════════════════════════════ -->
    <service>
      <timestamps>
        <debug>
          <datetime>
            <msec/>
          </datetime>
        </debug>
        <log>
          <datetime>
            <msec/>
          </datetime>
        </log>
      </timestamps>
    </service>

    <!-- ═══════════════════════════════════════════
         BANNER MOTD  (nieuw – bonus / security)
         Wettelijk vereiste toegangswaarschuwing.
         Bestaat nog niet → wordt puur toegevoegd.
    ═══════════════════════════════════════════ -->
    <banner>
      <motd>
        <banner>
          ^
          ******************************************************************
          *  WAARSCHUWING: Geautoriseerde toegang uitsluitend toegestaan.  *
          *  Alle activiteiten worden gelogd en gemonitord.                *
          *  Onbevoegde toegang wordt strafrechtelijk vervolgd.            *
          *  LAB-RA07-C02-R01 – Beheerd door netwerkbeheer                *
          ******************************************************************
          ^
        </banner>
      </motd>
    </banner>

    <!-- ═══════════════════════════════════════════
         DNS  (nieuw – bonus)
         Voegt domeinnaam en name-servers toe.
         Bestaat nog niet → wordt puur toegevoegd.
    ═══════════════════════════════════════════ -->
    <ip>
      <domain>
        <name>lab.local</name>
      </domain>
      <name-server>
        <no-vrf>
          <address>8.8.8.8</address>
        </no-vrf>
      </name-server>
      <name-server>
        <no-vrf>
          <address>8.8.4.4</address>
        </no-vrf>
      </name-server>
    </ip>

    <!-- ═══════════════════════════════════════════
         HTTP SERVER HARDENING  (nieuw – bonus / security)
         Schakelt onveilige HTTP management interface uit.
         Bestaat nog niet → wordt puur toegevoegd.
    ═══════════════════════════════════════════ -->
    <ip>
      <http>
        <server>false</server>
        <secure-server>false</secure-server>
      </http>
    </ip>

    <!-- ═══════════════════════════════════════════
         INTERFACES – ALLEEN DESCRIPTIONS BIJWERKEN
         IPs, masks, encapsulation, shutdown → NIET aangeraakt
    ═══════════════════════════════════════════ -->

    <!-- GigabitEthernet0/0/0 – Trunk parent -->
    <interface>
      <GigabitEthernet>
        <name>0/0/0</name>
        <description>TRUNK - Naar distributieswitch (VLAN 75/76/77/78/99)</description>
      </GigabitEthernet>
    </interface>

    <!-- GigabitEthernet0/0/0.75 – VLAN 75 Management -->
    <interface>
      <GigabitEthernet>
        <name>0/0/0.75</name>
        <description>VLAN 75 - Management | 172.17.7.64/28 | DHCP-relay 10.199.64.66</description>
      </GigabitEthernet>
    </interface>

    <!-- GigabitEthernet0/0/0.76 – VLAN 76 Data Users -->
    <interface>
      <GigabitEthernet>
        <name>0/0/0.76</name>
        <description>VLAN 76 - Data Users | 172.17.7.80/28 | DHCP-relay 10.199.64.66</description>
      </GigabitEthernet>
    </interface>

    <!-- GigabitEthernet0/0/0.77 – VLAN 77 Voice -->
    <interface>
      <GigabitEthernet>
        <name>0/0/0.77</name>
        <description>VLAN 77 - Voice | 172.17.7.96/28 | DHCP-relay 10.199.64.66</description>
      </GigabitEthernet>
    </interface>

    <!-- GigabitEthernet0/0/0.78 – VLAN 78 Reserved -->
    <interface>
      <GigabitEthernet>
        <name>0/0/0.78</name>
        <description>VLAN 78 - Reserved | 172.17.7.112/28 | DHCP-relay 10.199.64.66</description>
      </GigabitEthernet>
    </interface>

    <!-- GigabitEthernet0/0/0.99 – Native VLAN -->
    <interface>
      <GigabitEthernet>
        <name>0/0/0.99</name>
        <description>VLAN 99 - Native VLAN (untagged)</description>
      </GigabitEthernet>
    </interface>

    <!-- GigabitEthernet0/0/1 – WAN Uplink -->
    <interface>
      <GigabitEthernet>
        <name>0/0/1</name>
        <description>WAN Uplink | 10.199.65.96/27 | GW 10.199.65.100</description>
      </GigabitEthernet>
    </interface>

    <!-- ═══════════════════════════════════════════
         NTP  (nieuw – bonus)
         Tijdsynchronisatie via NTP-server.
         Bestaat nog niet → wordt puur toegevoegd.
    ═══════════════════════════════════════════ -->
    <ntp>
      <server>
        <server-list>
          <ip-address>10.199.65.100</ip-address>
        </server-list>
      </server>
    </ntp>

    <!-- ═══════════════════════════════════════════
         LOGGING / SYSLOG  (nieuw – bonus)
         Stuurt logs naar een centrale syslog-server.
         Bestaat nog niet → wordt puur toegevoegd.
    ═══════════════════════════════════════════ -->
    <logging>
      <host>
        <ipv4-host-list>
          <ipv4-host>10.199.64.66</ipv4-host>
        </ipv4-host-list>
      </host>
      <trap>informational</trap>
      <source-interface>
        <interface-name>GigabitEthernet0/0/0.75</interface-name>
      </source-interface>
    </logging>

    <!-- ═══════════════════════════════════════════
         OSPF ROUTING – VERBETERINGEN  (bonus)
         Voegt toe:
           • passive-interface default  → advertiseert subnetten
             zonder dat er OSPF hellos op die interfaces worden
             gestuurd (security best practice)
           • no passive-interface Gi0/0/1  → WAN-link blijft actief
             voor OSPF neighbor relationship
           • default-information originate  → distribueert de
             statische default route (0.0.0.0/0) in OSPF zodat
             andere routers die automatisch ontvangen
         IPs en network statements worden NIET aangeraakt.
    ═══════════════════════════════════════════ -->
    <router>
      <ospf xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-ospf">
        <id>1</id>
        <passive-interface>
          <interface>default</interface>
        </passive-interface>
        <passive-interface>
          <interface>no GigabitEthernet0/0/1</interface>
        </passive-interface>
        <default-information>
          <originate>
            <always/>
          </originate>
        </default-information>
      </ospf>
    </router>

  </native>
</config>